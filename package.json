{
  "name": "execution-intent-sdk",
  "version": "1.0.0",
  "description": "A minimal SDK for execution-bound commitments on top of delegation-framework primitives",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    }
  },
  "files": [
    "dist",
    "README.md"
  ],
  "scripts": {
    "build": "tsc",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "example:intent": "npx tsx examples/execution-intent/index.ts",
    "example:composition": "npx tsx examples/composition/index.ts",
    "example:onchain": "npx tsx examples/onchain/index.ts",
    "example:onchain:local": "bash scripts/run-onchain-example.sh",
    "example:composition:real": "bash scripts/run-composition-real.sh",
    "test:all": "bash scripts/test-all.sh",
    "consumer:test": "cd consumer-test && npm install --silent && npx tsx index.ts",
    "prepublishOnly": "npm run build && npm run typecheck"
  },
  "keywords": [
    "execution-intent",
    "eip712",
    "delegation",
    "relayer",
    "agent",
    "web3"
  ],
  "license": "MIT",
  "dependencies": {
    "dotenv": "^17.4.2",
    "viem": "^2.0.0"
  },
  "devDependencies": {
    "@types/node": "^25.6.0",
    "tsx": "^4.0.0",
    "typescript": "^5.0.0",
    "vitest": "^3.0.0"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/terriclaw/execution-intent-sdk.git"
  },
  "homepage": "https://github.com/terriclaw/execution-intent-sdk#readme",
  "bugs": {
    "url": "https://github.com/terriclaw/execution-intent-sdk/issues"
  },
  "module": "./dist/index.js"
}